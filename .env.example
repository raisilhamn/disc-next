# Turso (libsql) database
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# Optional: fallback to a local SQLite file when Turso vars are unset
# DATABASE_URL=file:./dev.db

# Optional: Upstash Redis (rate limiting + stats counter)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Auth.js — required in production. Generate with: npx auth secret
AUTH_SECRET=
